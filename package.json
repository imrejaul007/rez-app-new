{
  "name": "rez-consumer",
  "version": "1.0.0",
  "scripts": {
    "start": "NODE_OPTIONS=--max-old-space-size=8192 expo start",
    "start:clear": "NODE_OPTIONS=--max-old-space-size=8192 expo start --clear",
    "start:managed": "NODE_OPTIONS=--max-old-space-size=8192 node scripts/start-dev.js --clear",
    "start:lowmem": "NODE_OPTIONS=--max-old-space-size=4096 expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "clear-cache": "node ./scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8081",
    "lint": "expo lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "detox test --configuration ios.sim.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:build:ios": "detox build --configuration ios.sim.debug",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "verify:production": "ts-node scripts/verify-production-readiness.ts",
    "check:backend": "node scripts/check-backend.js",
    "verify:qr-sync": "npx tsx scripts/verify-qr-parser-sync.ts",
    "build:render": "npx expo export --platform web",
    "serve:render": "npx serve dist -p ${PORT:-3000} -s",
    "serve:web": "npx serve dist",
    "prepare": "husky",
    "preinstall": "node scripts/preinstall.js",
    "format": "prettier --write 'app/**/*.ts' 'app/**/*.tsx'"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
