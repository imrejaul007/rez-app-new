# REZ Consumer App (rez-master) — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# Core API — all traffic routes through the gateway.
# Source of truth: SOURCE-OF-TRUTH/API-ENDPOINTS.md
EXPO_PUBLIC_API_BASE_URL=https://rez-api-gateway.onrender.com/api
EXPO_PUBLIC_API_URL=https://rez-api-gateway.onrender.com/api
EXPO_PUBLIC_GATEWAY_URL=https://rez-api-gateway.onrender.com
EXPO_PUBLIC_BACKEND_URL=https://rez-backend-8dfu.onrender.com

# Auth Service
EXPO_PUBLIC_AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
EXPO_PUBLIC_REZ_AUTH_URL=https://rez-auth-service.onrender.com

# Service URLs
EXPO_PUBLIC_WALLET_SERVICE_URL=https://rez-wallet-service-36vo.onrender.com
EXPO_PUBLIC_PROFILE_SERVICE_URL=https://rezprofile.onrender.com
EXPO_PUBLIC_ECONOMIC_ENGINE_URL=https://rez-economic-engine.onrender.com
EXPO_PUBLIC_PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
EXPO_PUBLIC_SEARCH_SERVICE_URL=https://rez-search-service.onrender.com
EXPO_PUBLIC_CATALOG_SERVICE_URL=https://rez-catalog-service-1.onrender.com
EXPO_PUBLIC_ANALYTICS_SERVICE_URL=https://analytics-events-37yy.onrender.com
EXPO_PUBLIC_GAMIFICATION_SERVICE_URL=https://rez-gamification-service-3b5d.onrender.com

# Hotel OTA
EXPO_PUBLIC_HOTEL_OTA_URL=https://your-hotel-ota-url.com
EXPO_PUBLIC_OTA_CLIENT_ID=your_ota_client_id
EXPO_PUBLIC_OTA_CLIENT_SECRET=your_ota_client_secret

# Payments
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
EXPO_PUBLIC_ENABLE_RAZORPAY=true

# Cloudinary (media uploads)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# App Config
EXPO_PUBLIC_PROJECT_ID=your_eas_project_id_here
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_DSN=

# ReZ Mind Intent Capture
EXPO_PUBLIC_INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
EXPO_PUBLIC_REZ_MIND_URL=https://rez-event-platform.onrender.com

# AI Support Copilot
EXPO_PUBLIC_SUPPORT_COPILOT_URL=https://REZ-support-copilot.onrender.com

# REZ MIND Services
EXPO_PUBLIC_MERCHANT_COPILOT_URL=https://REZ-merchant-copilot.onrender.com
EXPO_PUBLIC_EVENT_PLATFORM_URL=https://REZ-event-platform.onrender.com
EXPO_PUBLIC_USER_INTELLIGENCE_URL=https://REZ-user-intelligence.onrender.com
EXPO_PUBLIC_KNOWLEDGE_BASE_URL=https://rez-knowledge-base.onrender.com
EXPO_PUBLIC_SEARCH_URL=https://rez-search-service.onrender.com

# Feature Flags
EXPO_PUBLIC_ENABLE_HOTEL_OTA=true
EXPO_PUBLIC_ENABLE_FLIGHTS=true
EXPO_PUBLIC_ENABLE_TRAINS=true
EXPO_PUBLIC_ENABLE_WALLET=true
EXPO_PUBLIC_SIMULATE_OTP=false
